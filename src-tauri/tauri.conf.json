{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reverie-link",
  "version": "0.1.0",
  "identifier": "io.github.ai.skyas.reverie-link",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:17420",
    "beforeBuildCommand": "npm run build && cd sidecar && python download_stt_model.py",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "reverie-link",
        "width": 160,
        "height": 185,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/models": "models"
    }
  }
}