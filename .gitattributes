# 默认：文本文件自动识别，仓库里存 LF
* text=auto eol=lf

# Rust / Cargo
*.rs        text eol=lf
*.toml      text eol=lf
Cargo.lock  text eol=lf

# 前端
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.vue       text eol=lf
*.json      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.md        text eol=lf

# Python
*.py        text eol=lf

# Windows 脚本必须 CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# 二进制资源
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.mp3       binary
*.wav       binary
*.mp4       binary

# Live2D 模型资源
*.moc3          binary
*.model3.json   text eol=lf
*.motion3.json  text eol=lf
*.physics3.json text eol=lf
*.cdi3.json     text eol=lf
*.exp3.json     text eol=lf